{
  "uid": "kostrack-agentic",
  "title": "Kostrack \u2014 Agentic Workflows",
  "description": "Cost per workflow run, span breakdown, trace analysis",
  "tags": [
    "kostrack"
  ],
  "timezone": "browser",
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "feature",
        "label": "Feature / Workflow",
        "type": "query",
        "datasource": {
          "uid": "kostrack-tsdb"
        },
        "query": "SELECT DISTINCT feature FROM trace_costs WHERE feature IS NOT NULL ORDER BY 1",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Workflow Runs",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT $__timeFrom() AS time, COUNT(*) AS value FROM trace_costs WHERE started_at >= $__timeFrom()",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Workflow Cost",
      "type": "stat",
      "gridPos": {
        "x": 5,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT $__timeFrom() AS time, SUM(total_cost_usd) AS value FROM trace_costs WHERE started_at >= $__timeFrom()",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg Cost per Run",
      "type": "stat",
      "gridPos": {
        "x": 10,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "mean"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT $__timeFrom() AS time, AVG(total_cost_usd) AS value FROM trace_costs WHERE started_at >= $__timeFrom()",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Calls per Run",
      "type": "stat",
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "mean"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT $__timeFrom() AS time, AVG(call_count) AS value FROM trace_costs WHERE started_at >= $__timeFrom()",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 5,
      "title": "Max Single Run Cost",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "max"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT $__timeFrom() AS time, MAX(total_cost_usd) AS value FROM trace_costs WHERE started_at >= $__timeFrom()",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 10,
      "title": "Avg Cost per Workflow Type",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6
        }
      },
      "options": {
        "orientation": "horizontal",
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT feature, AVG(total_cost_usd) AS avg_cost FROM trace_costs WHERE started_at >= $__timeFrom() AND feature IS NOT NULL GROUP BY 1 ORDER BY avg_cost DESC LIMIT 15",
          "format": "table"
        }
      ]
    },
    {
      "id": 11,
      "title": "Workflow Cost Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "mean"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT time_bucket('1 hour', started_at) AS time, feature, SUM(total_cost_usd) AS cost FROM trace_costs WHERE started_at >= $__timeFrom() AND feature IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 20,
      "title": "Most Expensive Workflow Runs",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "total_cost_usd"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 8
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "duration_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "total_cost_usd",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT trace_id, project, feature, call_count, total_cost_usd, input_tokens, output_tokens, ROUND(duration_ms::numeric) AS duration_ms, started_at FROM trace_costs ORDER BY total_cost_usd DESC LIMIT 50",
          "format": "table"
        }
      ]
    },
    {
      "id": 30,
      "title": "All Spans \u2014 Cost Breakdown",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cost_usd"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 8
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "latency_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "time",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "uid": "kostrack-tsdb"
          },
          "rawSql": "SELECT time, provider, model, tags->>'span_name' AS span, input_tokens, output_tokens, cached_tokens, cost_usd, latency_ms, trace_id FROM llm_calls WHERE trace_id IS NOT NULL AND $__timeFilter(time) ORDER BY time DESC LIMIT 200",
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}