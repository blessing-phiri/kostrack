# ── Database ───────────────────────────────────────────────────────────────────
TSDB_PASSWORD=changeme

# ── Grafana ────────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ── kostrack SDK ───────────────────────────────────────────────────────────────
KOSTRACK_DSN=postgresql://kostrack:changeme@localhost/kostrack

# ── kostrack Platform API ─────────────────────────────────────────────────────
# Bearer token for the REST API. Leave blank to disable auth (dev only).
KOSTRACK_API_KEY=

# ── LLM Provider keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...
DEEPSEEK_API_KEY=sk-...
